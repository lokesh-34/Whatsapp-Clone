# Frontend Environment Configuration
# Copy this file to .env.local (or .env) and fill in your values

# API base URL
# Leave empty when running with the Vite dev proxy to http://localhost:5000
VITE_API_URL=

# Firebase Web config (used for Google sign-in and phone auth)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
